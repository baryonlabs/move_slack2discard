SLACK_BOT_TOKEN=xoxb-...          # Slack Bot Token
SLACK_USER_TOKEN=xoxp-...         # Slack User Token (파일 다운로드용)
SLACK_WORKSPACE_ID=T...            # 워크스페이스 ID

DISCORD_BOT_TOKEN=...              # Discord Bot Token
DISCORD_GUILD_ID=...               # 마이그레이션 대상 서버 ID
DISCORD_ARCHIVE_CATEGORY_ID=...    # 아카이브 채널 카테고리 ID

DATA_DIR=./data                    # 로컬 데이터 저장 경로
DB_PATH=./data/archive.db          # SQLite DB 경로
FILES_DIR=./data/files             # 다운로드된 파일 저장 경로
